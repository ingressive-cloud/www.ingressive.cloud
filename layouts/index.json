{{- $pages := where .Site.RegularPages "Section" "docs" -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title":   {{ $p.Title | jsonify }},
    "url":     {{ $p.RelPermalink | jsonify }},
    "section": {{ $p.Parent.Title | jsonify }},
    "content": {{ $p.Plain | jsonify }}
  }
  {{- end }}
]
